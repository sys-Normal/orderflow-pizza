// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  buyer
  seller
  platform_admin
}

enum StoreStatus {
  pending
  approved
  suspended
  rejected
}

enum OrderStatus {
  received
  preparing
  ready
  delivering
  completed
  cancelled
}

enum PizzaSize {
  S
  M
  L
}

enum MenuCategory {
  pizza
  chicken
  side
  drink
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  role         Role
  createdAt    DateTime @default(now())

  // Populated when a buyer checks "이 배송지를 다음에도 사용하기" at checkout —
  // prefills the checkout form next time. `recentAddress*` is updated on
  // every successful order regardless of that checkbox, kept for future
  // reuse (e.g. a "최근 배송지" shortcut) even though nothing reads it yet.
  defaultAddressName  String?
  defaultAddressPhone String?
  defaultAddressLine  String?
  recentAddressName   String?
  recentAddressPhone  String?
  recentAddressLine   String?

  stores          Store[]
  orders          Order[]
  cart            Cart?
  deliveryPresets DeliveryPreset[]
}

// Named delivery addresses (e.g. "집", "회사") a buyer can save and reuse at
// checkout. Capped at 3 per user — enforced in src/lib/delivery/actions.ts,
// not at the schema level.
model DeliveryPreset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String
  name      String
  phone     String
  address   String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Per-buyer saved cart so a logged-in account keeps its cart across
// sessions/devices. Items are stored as a JSON string (SQLite has no native
// JSON type via Prisma) mirroring the localStorage CartItem[] shape.
model Cart {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id])
  itemsJson String
  updatedAt DateTime @updatedAt
}

model Store {
  id           String      @id @default(uuid())
  ownerId      String
  owner        User        @relation(fields: [ownerId], references: [id])
  name         String
  description  String?
  phone        String      @default("02-0000-0000")
  contactEmail String      @unique
  status       StoreStatus @default(pending)
  latitude     Float       @default(37.5665)
  longitude    Float       @default(126.9780)
  createdAt    DateTime    @default(now())

  menuItems MenuItem[]
  orders    Order[]

  @@index([ownerId])
}

model MenuItem {
  id          String       @id @default(uuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  name        String
  description String
  category    MenuCategory @default(pizza)
  priceS      Int
  priceM      Int
  priceL      Int
  imageUrl    String?
  isAvailable Boolean      @default(true)

  orderItems OrderItem[]

  @@index([storeId])
}

model Order {
  id        String      @id @default(uuid())
  storeId   String
  store     Store       @relation(fields: [storeId], references: [id])
  buyerId   String?
  buyer     User?       @relation(fields: [buyerId], references: [id])
  status    OrderStatus @default(received)
  subtotal  Int
  createdAt DateTime    @default(now())

  customerName    String
  customerPhone   String
  customerAddress String
  customerNotes   String?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([storeId])
  @@index([buyerId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  changedAt DateTime    @default(now())

  @@index([orderId])
}

model OrderItem {
  id         String    @id @default(uuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  name       String
  size       PizzaSize
  unitPrice  Int
  quantity   Int

  @@index([orderId])
}
